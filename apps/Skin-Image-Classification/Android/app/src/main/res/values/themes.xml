<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Plain platform theme with no action bar; Compose draws all UI. The window
         background matches the near-black app background so there is no flash. -->
    <style name="Theme.SkinClassifier" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/window_bg</item>
        <item name="android:statusBarColor">@color/window_bg</item>
        <item name="android:navigationBarColor">@color/window_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
